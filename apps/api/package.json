{
  "name": "@mass/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "format": "prettier --check \"src/**/*.{ts,tsx}\" prisma/schema.prisma"
  },
  "dependencies": {
    "@mass/domain": "workspace:*",
    "@nestjs/common": "^11.0.17",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.17",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.17",
    "@nestjs/websockets": "^11.0.17",
    "@prisma/client": "^6.6.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.48.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "express": "^5.1.0",
    "ioredis": "^5.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.5",
    "@nestjs/schematics": "^11.0.2",
    "@nestjs/testing": "^11.0.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.3",
    "@types/passport-jwt": "^4.0.1",
    "prettier": "^3.5.3",
    "prisma": "^6.6.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
